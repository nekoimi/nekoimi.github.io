---
import { t, loadTranslation, getLocaleFromPathname, getPathnameFromLocale } from '../i18n/translator';

const locale = getLocaleFromPathname(Astro.url.pathname);
const translationData = await loadTranslation(locale);

const footerLinks = {
  product: [
    { labelKey: 'footer.product_features', href: '#features' },
    { labelKey: 'footer.pricing', href: '#pricing' },
    { labelKey: 'footer.documentation', href: getPathnameFromLocale(locale, '/docs') },
    { labelKey: 'footer.api_reference', href: getPathnameFromLocale(locale, '/api') },
  ],
  company: [
    { labelKey: 'footer.about', href: getPathnameFromLocale(locale, '/about') },
    { labelKey: 'footer.blog', href: getPathnameFromLocale(locale, '/blog') },
    { labelKey: 'footer.careers', href: getPathnameFromLocale(locale, '/careers') },
  ],
  support: [
    { labelKey: 'footer.help_center', href: getPathnameFromLocale(locale, '/support') },
    { labelKey: 'footer.faq', href: getPathnameFromLocale(locale, '/faq') },
    { labelKey: 'footer.contact', href: '#contact' },
    { labelKey: 'footer.status', href: getPathnameFromLocale(locale, '/status') },
  ],
};

const socialLinks = [
  { name: 'Twitter', icon: '𝕏', href: 'https://twitter.com/synthworks' },
  { name: 'GitHub', icon: '💻', href: 'https://github.com/synthworks' },
  { name: 'Discord', icon: '💬', href: 'https://discord.gg/synthworks' },
  { name: 'LinkedIn', icon: '💼', href: 'https://linkedin.com/company/synthworks' },
];

const currentYear = new Date().getFullYear();
---

<footer id="contact" class="bg-gray-900 text-white py-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-12 mb-12">
      <!-- Logo & Description -->
      <div class="lg:col-span-2">
        <a href={getPathnameFromLocale(locale, '/')} class="text-2xl font-bold gradient-text inline-block mb-4">SynthWorks</a>
        <p class="text-gray-400 mb-6 leading-relaxed">
          {t(translationData, 'footer.description')}
        </p>

        <!-- Social Links -->
        <div class="flex gap-4">
          {socialLinks.map(link => (
            <a
              href={link.href}
              class="w-10 h-10 bg-gray-800 rounded-full flex items-center justify-center hover:bg-primary transition-colors"
              aria-label={link.name}
              target="_blank"
              rel="noopener noreferrer"
            >
              <span class="text-lg">{link.icon}</span>
            </a>
          ))}
        </div>
      </div>

      <!-- Product Links -->
      <div>
        <h4 class="text-lg font-semibold mb-4">{t(translationData, 'footer.product')}</h4></h4>
        <ul class="space-y-3">
          {footerLinks.product.map(link => (
            <li>
              <a
                href={link.href}
                class="text-gray-400 hover:text-white transition-colors"
              >
                {t(translationData, link.labelKey)}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company Links -->
      <div>
        <h4 class="text-lg font-semibold mb-4">{t(translationData, 'footer.company')}</h4>
        <ul class="space-y-3">
          {footerLinks.company.map(link => (
            <li>
              <a
                href={link.href}
                class="text-gray-400 hover:text-white transition-colors"
              >
                {t(translationData, link.labelKey)}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Support Links -->
      <div>
        <h4 class="text-lg font-semibold mb-4">{t(translationData, 'footer.support')}</h4>
        <ul class="space-y-3">
          {footerLinks.support.map(link => (
            <li>
              <a
                href={link.href}
                class="text-gray-400 hover:text-white transition-colors"
              >
                {t(translationData, link.labelKey)}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="border-t border-gray-800 pt-8">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-gray-400 text-sm">
          &copy; {currentYear} SynthWorks. {t(translationData, 'footer.copyright')}
        </p>
        <div class="flex gap-6 text-sm">
          <a href={getPathnameFromLocale(locale, '/privacy')} class="text-gray-400 hover:text-white transition-colors">
            {t(translationData, 'footer.privacy')}
          </a>
          <a href={getPathnameFromLocale(locale, '/terms')} class="text-gray-400 hover:text-white transition-colors">
            {t(translationData, 'footer.terms')}
          </a>
          <a href={getPathnameFromLocale(locale, '/cookies')} class="text-gray-400 hover:text-white transition-colors">
            {t(translationData, 'footer.cookies')}
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>
