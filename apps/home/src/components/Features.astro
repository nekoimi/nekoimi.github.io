---
import { t, loadTranslation, getLocaleFromPathname } from '../i18n/translator';

const locale = getLocaleFromPathname(Astro.url.pathname);
const translationData = await loadTranslation(locale);

const features = [
  {
    titleKey: 'features.face_swap.title',
    descKey: 'features.face_swap.desc',
    icon: '🎭',
  },
  {
    titleKey: 'features.tts.title',
    descKey: 'features.tts.desc',
    icon: '🎤',
  },
  {
    titleKey: 'features.ocr.title',
    descKey: 'features.ocr.desc',
    icon: '📝',
  },
  {
    titleKey: 'features.video.title',
    descKey: 'features.video.desc',
    icon: '🎬',
  },
];
---

<section id="features" class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold mb-4">
        <span class="gradient-text">{t(translationData, 'features.title')}</span>
      </h2>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto">
        {t(translationData, 'features.subtitle')}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {features.map(feature => (
        <div class="bg-gradient-to-br from-white to-gray-50 rounded-2xl p-8 shadow-sm hover:shadow-xl hover:-translate-y-2 transition-all duration-300 border border-gray-100">
          <div class="text-5xl mb-4">{feature.icon}</div>
          <h3 class="text-xl font-bold mb-3 text-gray-900">{t(translationData, feature.titleKey)}</h3>
          <p class="text-gray-600 leading-relaxed">{t(translationData, feature.descKey)}</p>
        </div>
      ))}
    </div>
  </div>
</section>
