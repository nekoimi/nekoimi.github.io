---
import { t, loadTranslation, getLocaleFromPathname } from '../i18n/translator';

const locale = getLocaleFromPathname(Astro.url.pathname);
const translationData = await loadTranslation(locale);

const tools = [
  {
    titleKey: 'tools.face_swap.title',
    descKey: 'tools.face_swap.desc',
    tag1Key: 'tools.face_swap.tag1',
    tag2Key: 'tools.face_swap.tag2',
    href: '#tools',
  },
{
    titleKey: 'tools.voice.title',
    descKey: 'tools.voice.desc',
    tag1Key: 'tools.voice.tag1',
    tag2Key: 'tools.voice.tag2',
    href: '#tools',
  },
  {
    titleKey: 'tools.ocr.title',
    descKey: 'tools.ocr.desc',
    tag1Key: 'tools.ocr.tag1',
    tag2Key: 'tools.ocr.tag2',
    href: '#tools',
  },
  {
    titleKey: 'tools.video_editing.title',
    descKey: 'tools.video_editing.desc',
    tag1Key: 'tools.video_editing.tag1',
    tag2Key: 'tools.video_editing.tag2',
    href: '#tools',
  },
  {
    titleKey: 'tools.image_processing.title',
    descKey: 'tools.image_processing.desc',
    tag1Key: 'tools.image_processing.tag1',
    tag2Key: 'tools.image_processing.tag2',
    href: '#tools',
  },
  {
    titleKey: 'tools.subtitle_extraction.title',
    descKey: 'tools.subtitle_extraction.desc',
    tag1Key: 'tools.subtitle_extraction.tag1',
    tag2Key: 'tools.subtitle_extraction.tag2',
    href: '#tools',
  },
];
---

<section id="tools" class="py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold mb-4">
        <span class="gradient-text">{t(translationData, 'tools.title')}</span>
      </h2>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto">
        {t(translationData, 'tools.subtitle')}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {tools.map(tool => (
        <a
          href={tool.href}
          class="group bg-gradient-to-br from-white to-gray-50 rounded-2xl p-8 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 border border-gray-100 h-full"
        >
          <h3 class="text-xl font-bold mb-3 text-gray-900 group-hover:text-primary transition-colors">
            {t(translationData, tool.titleKey)}
          </h3>
          <p class="text-gray-600 mb-4 leading-relaxed">{t(translationData, tool.descKey)}</p>
          <div class="flex flex-wrap gap-2">
            <span class="px-3 py-1 bg-indigo-50 text-primary text-sm rounded-full border border-indigo-100">
              {t(translationData, tool.tag1Key)}
            </span>
            <span class="px-3 py-1 bg-indigo-50 text-primary text-sm rounded-full border border-indigo-100">
              {t(translationData, tool.tag2Key)}
            </span>
          </div>
        </a>
      ))}
    </div>

    <div class="text-center mt-12">
      <a
        href="#pricing"
        class="inline-flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-primary to-secondary text-white font-semibold rounded-xl hover:shadow-lg transition-all"
      >
        {t(translationData, 'tools.view_all')}
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
