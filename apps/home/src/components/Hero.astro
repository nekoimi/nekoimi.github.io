---
import { t, loadTranslation, getLocaleFromPathname } from '../i18n/translator';

const locale = getLocaleFromPathname(Astro.url.pathname);
const translationData = await loadTranslation(locale);
---

<section class="relative pt-32 pb-24 overflow-hidden">
  <!-- Background Gradient -->
  <div class="absolute inset-0 bg-gradient-to-br from-indigo-50 via-white to-purple-50"></div>
  <div class="absolute top-20 right-20 w-96 h-96 bg-purple-200 rounded-full blur-3xl opacity-20"></div>
  <div class="absolute bottom-20 left-20 w-96 h-96 bg-indigo-200 rounded-full blur-3xl opacity-20"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <!-- Main Title -->
    <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold mb-8">
      <span class="gradient-text">{t(translationData, 'hero.title')}</span>
      <br />
      <span class="text-gray-900">{t(translationData, 'hero.title_gradient')}</span>
    </h1>

    <!-- Subtitle -->
    <p class="text-xl md:text-2xl text-gray-600 mb-12 max-w-3xl mx-auto leading-relaxed">
      {t(translationData, 'hero.subtitle')}
    </p>

    <!-- CTA Buttons -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="#tools"
        class="px-8 py-4 bg-gradient-to-r from-primary to-secondary text-white text-lg font-semibold rounded-xl hover:shadow-xl hover:-translate-y-1 transition-all shadow-lg"
      >
        {t(translationData, 'hero.cta_primary')}
      </a>
      <a
        href="#features"
        class="px-8 py-4 bg-white border-2 border-gray-200 text-gray-700 text-lg font-semibold rounded-xl hover:border-primary hover:text-primary transition-all"
      >
        {t(translationData, 'hero.cta_secondary')}
      </a>
    </div>
  </div>
</section>
