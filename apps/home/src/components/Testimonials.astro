---
import { t, loadTranslation, getLocaleFromPathname } from '../i18n/translator';

const locale = getLocaleFromPathname(Astro.url.pathname);
const translationData = await loadTranslation(locale);

const testimonials = [
  {
    nameKey: 'testimonials.user1.name',
    roleKey: 'testimonials.user1.role',
    companyKey: 'testimonials.user1.company',
    avatar: '👏',
    contentKey: 'testimonials.user1.content',
    rating: 5,
  },
  {
    nameKey: 'testimonials.user2.name',
    roleKey: 'testimonials.user2.role',
    companyKey: 'testimonials.user2.company',
    avatar: '🎥',
    contentKey: 'testimonials.user2.content',
    rating: 5,
  },
  {
    nameKey: 'testimonials.user3.name',
    roleKey: 'testimonials.user3.role',
    companyKey: 'testimonials.user3.company',
    avatar: '🚀',
    contentKey: 'testimonials.user3.content',
    rating: 4,
  },
];
---

<section id="testimonials" class="py-24 bg-gradient-to-br from-purple-50 via-white to-indigo-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold mb-4">
        <span class="gradient-text">{t(translationData, 'testimonials.title')}</span>
      </h2>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto">
        {t(translationData, 'testimonials.subtitle')}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {testimonials.map(testimonial => (
        <div class="bg-white rounded-2xl p-8 shadow-sm hover:shadow-lg transition-all duration-300 border border-gray-100">
          <div class="flex items-start gap-4 mb-4">
            <div class="text-4xl">{testimonial.avatar}</div>
            <div class="flex-1">
              <h3 class="font-bold text-gray-900">{t(translationData, testimonial.nameKey)}</h3>
              <p class="text-sm text-gray-500">{t(translationData, testimonial.roleKey)} at {t(translationData, testimonial.companyKey)}</p>
            </div>
          </div>
          <p class="text-gray-600 mb-4 leading-relaxed">"{t(translationData, testimonial.contentKey)}"</p>
          <div class="flex gap-1">
            {Array.from({ length: 5 }).map((_, i) => (
              <svg
                class={`w-5 h-5 ${i < testimonial.rating ? 'text-yellow-400' : 'text-gray-300'}`}
                fill="currentColor"
                viewBox="0 0 20 20"
              >
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
        </div>
      ))}
    </div>

    <div class="text-center mt-12">
      <a
        href="#contact"
        class="inline-flex items-center gap-2 px-6 py-3 bg-white border-2 border-gray-200 text-gray-700 font-semibold rounded-xl hover:border-primary hover:text-primary transition-all"
      >
        {t(translationData, 'testimonials.share_experience')}
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
