---
import { t, loadTranslation, getLocaleFromPathname } from '../i18n/translator';

const locale = getLocaleFromPathname(Astro.url.pathname);
const translationData = await loadTranslation(locale);

const stats = [
  { labelKey: 'stats.tasks', value: '10,000+' },
  { labelKey: 'stats.daily', value: '100K+' },
  { labelKey: 'stats.users', value: '5,000+' },
  { labelKey: 'stats.uptime', value: '99.9%' },
];
---

<section class="py-20 bg-white border-y border-gray-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 md:gap-12">
      {stats.map(stat => (
        <div class="text-center group">
          <div class="text-4xl md:text-5xl font-bold gradient-text mb-2 group-hover:scale-105 transition-transform">
            {stat.value}
          </div>
          <div class="text-gray-600 text-sm md:text-base">{t(translationData, stat.labelKey)}</div>
        </div>
      ))}
    </div>
  </div>
</section>
