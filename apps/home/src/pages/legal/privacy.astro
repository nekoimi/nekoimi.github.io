---
import { t, loadTranslation, getLocaleFromPathname, getPathnameFromLocale } from '../i18n/translator';

const locale = getLocaleFromPathname(Astro.url.pathname);
const translationData = await loadTranslation(locale);
const title = t(translationData, 'footer.privacy) || 'Privacy Policy';
---

<Layout title={title}>
  <Navbar />
  <section class="pt-32 pb-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl md:text-5xl font-bold mb-8">
        <span class="gradient-text">{title}</span>
      </h1>
      <div class="prose prose prose-lg prose-gray">
        <p class="text-xl text-gray-600 mb-6">
          At SynthWorks, we take your privacy seriously. This Privacy Policy explains how we collect, use, and protect your personal information.
        </p>

        <h2 class="text-2xl font-bold mt-8 mb-4">Information We Collect</h2>
        <p class="text-gray-600 mb-4">We collect information you provide directly to us when you use our services, including:</p>
        <ul class="list-disc pl-6 text-gray-600 mb-6 space-y-2">
          <li>Account information (name, email address)</li>
          <li>Payment information (processed securely through third-party providers)</li>
          <li>Usage data and analytics</li>
          <li>Files and content you upload for processing</li>
        </ul>

        <h2 class="text-2xl font-bold mt-8 mb-4">How We Use Your Information</h2>
        <p class="text-gray-600 mb-4">We use the collected information to:</p>
        <ul class="list-disc pl-6 text-gray-600 mb-6 space-y-2">
          <li>Provide and improve our services</li>
          <li>Process your requests and deliver results</li>
          <li>Communicate with you about your account</li>
          <li>Analyze usage patterns to enhance user experience</li>
        </ul>

        <h2 class="text-2xl font-bold mt-8 mb-4">Data Security</h2>
        <p class="text-gray-600 mb-6">
          We implement industry-standard security measures to protect your information. Your uploaded files are encrypted and automatically deleted after processing is complete.
        </p>

        <h2 class="text-2xl font-bold mt-8 mb-4">Your Rights</h2>
        <p class="text-gray-600 mb-4">You have the right to:</p>
        <ul class="list-disc pl-6 text-gray-600 mb-6 space-y-2">
          <li>Access your personal information</li>
          <li>Correct inaccurate information</li>
          <li>Request deletion of your data</li>
          <li>Opt-out of marketing communications</li>
        </ul>

        <h2 class="text-2xl font-bold mt-8 mb-4">Contact Us</h2>
        <p class="text-gray-600 mb-6">
          If you have questions about this Privacy Policy or our data practices, please contact us at privacy@synthworks.com
        </p>

        <p class="text-sm text-gray-500">
          Last updated: March 2026
        </p>
      </div>
    </div>
  </section>
  <Footer />
</Layout>
