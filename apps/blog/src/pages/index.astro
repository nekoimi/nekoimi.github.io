---
import BlogLayout from '../layouts/BlogLayout.astro';
import Header from '../components/Header.astro';
import BlogCard from '../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BlogLayout title="SynthWorks Blog - AI Automation Insights">
  <Header />
  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-12">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">
        <span class="gradient-text">SynthWorks Blog</span>
      </h1>
      <p class="text-xl text-gray-600">
        Insights, tutorials, and news about AI automation and digital creativity
      </p>
    </div>

    {allPosts.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {allPosts.map(post => <BlogCard post={post} />)}
      </div>
    ) : (
      <div class="text-center py-12">
        <p class="text-gray-500">No blog posts yet. Stay tuned!</p>
      </div>
    )}
  </main>
</BlogLayout>
