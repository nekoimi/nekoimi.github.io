---
interface Props {
  variant?: 'primary' | 'secondary';
  href: string;
  children: string;
}

const { variant = 'primary', href, children } = Astro.props;

const isPrimary = variant === 'primary';
const classes = isPrimary
  ? 'bg-gradient-to-r from-blue-600 to-purple-600 text-white hover:shadow-lg hover:shadow-blue-500/30'
  : 'bg-white text-gray-900 border border-gray-200 hover:border-gray-300 hover:bg-gray-50';
---

<a href={href} class={`inline-flex items-center gap-2 font-medium px-6 py-3 rounded-lg transition-all duration-300 ${classes}`}>
  {children}
  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5-5M13 17l5 5m0 0l-5-5M6 13H4m0 0l2-4m0 0l-2 4M6 11H4m0 0l2-4m0 0l-2-4" />
  </svg>
</a>
